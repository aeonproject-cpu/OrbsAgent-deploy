# ─────────────────────────────────────────────
# ORBS AGENT — Environment Variables Example
# Copy this file to .env and fill in the values
# cp .env.example .env
# ─────────────────────────────────────────────

# ── App ───────────────────────────────────────
APP_NAME=orbs-agent
APP_ENV=production
APP_URL=https://orbsagent.xyz
APP_PORT=3000

# ── API ───────────────────────────────────────
API_BASE_URL=https://api.orbsagent.xyz/v1
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
API_RATE_LIMIT=300

# ── Blockchain ────────────────────────────────
RPC_ETHEREUM=https://mainnet.infura.io/v3/your_project_id
RPC_BASE=https://mainnet.base.org
RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_SOLANA=https://api.mainnet-beta.solana.com

CONTRACT_REGISTRY=0x0000000000000000000000000000000000000000
CONTRACT_REPUTATION=0x0000000000000000000000000000000000000000
CONTRACT_STAKING=0x0000000000000000000000000000000000000000
CONTRACT_TRUST_RESOLVER=0x0000000000000000000000000000000000000000

# ── ORBS Token ────────────────────────────────
ORBS_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
ORBS_CHAIN_ID=1

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/orbsagent
REDIS_URL=redis://localhost:6379

# ── Analytics ─────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token

# ── Social ────────────────────────────────────
TWITTER_HANDLE=orbsagent
GITHUB_REPO=https://github.com/your-username/orbs-agent
DISCORD_INVITE=https://discord.gg/orbsagent
TELEGRAM_LINK=https://t.me/orbsagent

# ── Email / Notifications ─────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=hello@orbsagent.xyz
SMTP_PASS=your_smtp_password

# ── CDN / Storage ─────────────────────────────
CDN_URL=https://cdn.orbsagent.xyz
S3_BUCKET=orbs-agent-assets
S3_REGION=us-east-1
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
